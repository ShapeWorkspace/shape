# Core server
DATABASE_URL=postgres://localhost/conquer?sslmode=disable
SESSION_SECRET=your-secret-key-change-me
SESSION_COOKIE_DOMAIN=
# PORT is required - no default
PORT=
ENVIRONMENT=development
# i.e http://localhost:${PORT} or https://app.shape.work
HOST=
WORKSPACE_ROOT_DOMAIN=shape.local
WORKSPACE_URL_SCHEME=http
SESSION_COOKIE_DOMAIN=.shape.local
# ALLOWED_ORIGINS must include your CLIENT_PORT (e.g., http://localhost:5173)
# No default - you must set this explicitly based on your VITE_CLIENT_PORT
ALLOWED_ORIGINS=
REQUIRE_INVITE_CODE=false


# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Email
# Choose driver: "ses" (production) or "smtp" (local/dev)
EMAIL_DRIVER=smtp
AWS_REGION=us-east-1
SES_SENDER_EMAIL=
SES_ENABLED=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# Metrics
METRICS_DRIVER=none
METRICS_NAMESPACE=Conquer/App

# AWS S3 Configuration
# Two buckets are used: one private for encrypted files, one public for avatars
# AWS credentials are loaded via standard SDK chain (IAM role, env vars, or shared credentials file)

# Private bucket for encrypted file blobs (accessed via presigned URLs)
S3_FILES_BUCKET_NAME=files
# Public bucket for avatar images (directly accessible URLs)
S3_AVATARS_BUCKET_NAME=avatars
# AWS region for both buckets (defaults to AWS_REGION if not set)
S3_REGION=us-east-1

# Local development with MinIO (uncomment for local dev)
S3_ENDPOINT_URL=http://localhost:9000
S3_AVATARS_PUBLIC_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio12345

# Redis (optional for SSE replication across instances)
REDIS_ENABLED=false
REDIS_ADDRESS=localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
REDIS_CHANNEL=conquer:sse

# APNs (Apple Push Notification service)
APNS_KEY_BASE64=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_ENVIRONMENT=sandbox
