{
  "name": "@shape/monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "web",
    "engine",
    "plugins",
    "emails",
    "desktop",
    "admin",
    "website"
  ],
  "scripts": {
    "build": "yarn workspace @shape/web build && yarn workspace @shape/emails build && yarn workspace @shape/website build && yarn workspace @shape/admin build",
    "emails": "yarn workspace @shape/emails build",
    "desktop:build": "yarn workspace @shape/desktop build",
    "desktop": "yarn workspace @shape/desktop dev",
    "dev": "yarn workspace @shape/web dev",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "icons:client": "pwa-asset-generator ./icon.png ./client/public --favicon --manifest ./client/public/site.webmanifest --icon-only --maskable --background '#000000' --padding '0'",
    "icons:website": "pwa-asset-generator ./icon.png ./website/public --favicon --manifest ./website/public/site.webmanifest --icon-only --maskable --background '#000000' --padding '0'",
    "icons": "yarn icons:client && yarn icons:website",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:client": "yarn workspace @shape/web lint && eslint client engine --ext .ts,.tsx,.js,.jsx --fix",
    "lint:website": "eslint website/src --ext .ts,.tsx,.js,.jsx --fix",
    "lint": "yarn workspace @shape/web lint && eslint . --ext .ts,.tsx,.js,.jsx",
    "storybook": "yarn workspace @shape/web storybook",
    "build-storybook": "yarn workspace @shape/web build-storybook",
    "lint:actions": "actionlint",
    "playwright:headed": "yarn workspace @shape/web playwright:headed",
    "playwright:install": "yarn workspace @shape/web playwright:install",
    "playwright:ui": "yarn workspace @shape/web playwright:ui",
    "playwright": "yarn workspace @shape/web playwright",
    "bump:mobile": "node scripts/bump-mobile-version.mjs",
    "preview": "yarn workspace @shape/web preview",
    "r": "killall Cursor 2>/dev/null || true && sleep 1 && open -a Cursor .",
    "test:components": "vitest run client/",
    "test": "vitest run",
    "test:playwright": "yarn playwright",
    "test:playwright:ui": "yarn playwright:ui",
    "test:playwright:headed": "yarn playwright:headed",
    "test:engine": "vitest run engine/",
    "test:engine:int": "yarn workspace @shape/engine test:int",
    "test:server": "cd server && go test ./...",
    "serverlogs": "tail -f ./server/server-app.log | grep 'APPLOG'"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tauri-apps/cli": "^2.9.6",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "pwa-asset-generator": "^6.4.0",
    "sass-embedded": "^1.93.3",
    "typescript": "^5.0.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "yarn@4.9.2",
  "resolutions": {
    "prosemirror-state": "1.4.4",
    "prosemirror-view": "1.41.3",
    "prosemirror-model": "1.25.2",
    "prosemirror-transform": "1.10.4",
    "prosemirror-commands": "1.7.1",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-history": "1.4.1",
    "prosemirror-inputrules": "1.5.0",
    "prosemirror-schema-basic": "1.2.4",
    "prosemirror-schema-list": "1.5.1",
    "prosemirror-dropcursor": "1.8.2",
    "prosemirror-gapcursor": "1.4.0",
    "prosemirror-tables": "1.8.1"
  },
  "dependencies": {
    "@tiptap/extension-list": "^3.11.1",
    "@tiptap/extension-unique-id": "^3.11.1"
  }
}
